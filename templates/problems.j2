{% from 'problem-card.j2' import card with context %}
<!DOCTYPE html>
<html>
<head>
  {% include "common_header.j2" %}
  <title>Problems</title>
</head>
<body class="dark:bg-black dark:text-white h-full">
  {% include "menubar.j2" %}
  <h1 class="p-4 text-4xl font-bold text-center">Problems</h1>
  <div class="md:p-8 p-4 grid grid-cols-1 md:grid-cols-3 md:gap-8 gap-4 md:min-h-[700px]">
    {%- for prob in problems.values() %}
      {{ card(prob["route"], prob["title"], prob["image"]) }}
    {%- endfor %}
  </div>
</body>
</html>
