{% macro card(route, title_, scores, db_entry, norms) -%}
  <div class="p-4 text-center dark:bg-gray-900 bg-white rounded 
              ring-2 dark:ring-blue-500/50 grid grid-cols-1 content-center">
    <div>
      <a href="/problems/{{ route }}">
        <h2 class="mx-auto font-bold text-2xl">{{ title_ }}</h2>
      </a>
    </div>
    <div>
      {% if scores[db_entry] == None %}
        <h2 class="mx-auto font-bold text-5xl">No score.</h2>
      {% else %}
        <h2 class="mx-auto font-bold text-5xl">{{ scores[db_entry] }}</h2>
        <h2 class="mx-auto font-bold text-2xl">
          Norm: {{ norms[db_entry]|round(2, 'common')}}
        </h2>
      {% endif %}
    </div>
    <div class="items-center">
    </div>
  </div>
{%- endmacro %}
