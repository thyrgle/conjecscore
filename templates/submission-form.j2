<form id="form" class="grid grid-cols-1 md:grid-cols-2 gap-4 md:max-h-full w-full md:px-3 md:col-span-2" method=POST>
  <div>
  {% if submission_type == "csv" or submission_type == "json" %}	  
    <input class="submit-transition submit-file-shape w-full" 
           type="file" 
           id="submission"
           accept=".{{ submission_type }}"
           name="submission"></input>
  {% else %}
    <input class="submit-txt w-full"
           type="{{ submission_type }}"
           id="submission"
           name="submission"></input>
  {% endif %}
  </div>
  <div>
    <input class="submit-transition submit-btn-shape w-full"
           type="submit"
	   value="Submit"></input>
  </div>
  {# Only one variant, disable dropdown #}
  {% if variant_labels|length == 1 %}
  <div id="status" class="font-bold md:col-span-2">
    <!-- For status of submission. -->
  </div>
  {% else %}
  <div id="status" class="font-bold md:col-span-1">
    <!-- For status of submission. -->
  </div>
  <div class="md:col-span-1">
    <select class="md:col-span-1" name="variants", id="variant-select">
      <option value="score">{{ default_name }}</option>
      {% for name, function in variant_data %}
        {% if name != default_name %}		    
          <option value="{{ function }}">{{ name }}</option>
        {% endif %}
      {% endfor %}
    </select>
  {% endif %}
</form>
