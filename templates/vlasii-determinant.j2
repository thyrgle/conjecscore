{% extends "problem_template.j2" %}

{% block problem_description %}
  <p>
  The Vlasii Determinant Problem asks what is the maximum value of the determinant of an \(n \times n\) matrix where each row is a permutation of \(1, \ldots, 10\). The optimal determinant is known up to \(n = 9\). This problem asks you to come up with a \(10 \times 10\) matrix such that the determinant is as large as possible.
  </p>
{% endblock %}

{% block submission_format %}
  <p>
  Please submit a CSV file that contains \(10 \times 10 = 100\) values. Furthermore, every \(10\) values of the CSV corresponds to a row of a matrix, call it \(M\). Therefore, each \(10\) values should be some permutation of \(1, \ldots, 10\). The best score corresponds to maximizing \(\det(M)\).
  </p>
{% endblock %}
{% block score_func %}
import numpy as np
from sympy import Matrix


def score(mat: [int]):
    # Not the correct size.
    if len(mat) != 10 * 10:
        return None

    # Each row should have {1, ..., 10} in it.
    np_mat = np.reshape(mat, (10, 10))
    # {1, ..., 10}
    nums = set(range(1, 11))
    for i in range(10):
        row = set(mat[i])
        if set(row) != nums:
            return None

    sym_mat = Matrix(np_mat)
    return sym_mat.det()
{% endblock %}
{% block filetype %}.csv{% endblock %}
