{# title is a built in, I use title_ instead #}
{% macro card(route, title_, image) -%}
  <div class="p-4 text-center dark:bg-gray-900 bg-white rounded 
	      ring-2 dark:ring-blue-500/50 grid grid-cols-1">
    <div>
      <a href="/problems/{{ route }}">
        <h2 class="mx-auto font-bold text-2xl">{{ title_ }}</h2>
      </a>
    </div>
    <div class="items-center">
      <a href="/problems/{{ route }}">
        <img class="dark:invert w-80 mx-auto 
                    max-h-40 min-h-40 md:max-h-100 md:min-h-100"
	     src="{{ url_for('static', path='/' + image) }}"/>
      </a>
    </div>
  </div>
{%- endmacro %}
